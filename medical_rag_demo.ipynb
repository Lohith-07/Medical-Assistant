 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🩺 Medical RAG Pipeline Walkthrough & Metrics\n",
    "\n",
    "Welcome to the **Medical RAG Assistant** notebook. This notebook demonstrates the end-to-end pipeline of our clinical document Q&A assistant in a clean, step-by-step format.\n",
    "\n",
    "We will cover:\n",
    "1. **Document Loading**: Extracting text pages from a PDF.\n",
    "2. **Text Chunking**: Splitting the document into overlapping chunks.\n",
    "3. **Local Embedding Generation**: Vectorizing text using `sentence-transformers/all-MiniLM-L6-v2`.\n",
    "4. **Vector Store Indexing**: Loading and querying a local `ChromaDB` index.\n",
    "5. **Semantic Retrieval with Metrics**: Querying the database and analyzing **L2 Distance similarity scores**.\n",
    "6. **Grounded QA with Gemini**: Sending context chunks to `gemini-2.5-flash` and measuring response latency."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 1: Initialize Environment and Imports"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import time\n",
    "from dotenv import load_dotenv\n",
    "from langchain_community.document_loaders import PyPDFLoader\n",
    "from langchain_text_splitters import RecursiveCharacterTextSplitter\n",
    "from langchain_community.embeddings import HuggingFaceEmbeddings\n",
    "from langchain_community.vectorstores import Chroma\n",
    "from langchain_google_genai import ChatGoogleGenerativeAI\n",
    "from langchain_core.prompts import ChatPromptTemplate\n",
    "\n",
    "# Load environment variables from .env file\n",
    "load_dotenv()\n",
    "api_key = os.getenv(\"GEMINI_API_KEY\") or os.getenv(\"GOOGLE_API_KEY\")\n",
    "\n",
    "if api_key:\n",
    "    print(\"✅ Environment configured successfully!\")\n",
    "    print(f\"API Key active (starts with): {api_key[:10]}...\")\n",
    "else:\n",
    "    print(\"⚠️ Warning: Gemini API Key is missing. Please check your .env file.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 2: Document Loading"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load a sample medical PDF\n",
    "pdf_path = \"data/sample_medical.pdf\"\n",
    "\n",
    "if not os.path.exists(pdf_path):\n",
    "    print(f\"❌ Test PDF file not found at '{pdf_path}'. Please upload or download a PDF first.\")\n",
    "else:\n",
    "    loader = PyPDFLoader(pdf_path)\n",
    "    pages = loader.load()\n",
    "    print(f\"📄 Successfully loaded PDF: '{pdf_path}'\")\n",
    "    print(f\"📊 Total pages extracted: {len(pages)}\")\n",
    "    print(\"--- First Page Content Preview ---\")\n",
    "    print(pages[0].page_content[:300])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 3: Text Chunking"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Splitting pages into smaller, semantically rich chunks\n",
    "chunk_size = 700\n",
    "chunk_overlap = 100\n",
    "\n",
    "splitter = RecursiveCharacterTextSplitter(\n",
    "    chunk_size=chunk_size,\n",
    "    chunk_overlap=chunk_overlap,\n",
    "    add_start_index=True\n",
    ")\n",
    "\n",
    "chunks = splitter.split_documents(pages)\n",
    "print(f"\"[Chunking Stats]\"\\n\")\n",
    "print(f\"- Original pages: {len(pages)}\")\n",
    "print(f\"- Resulting text chunks: {len(chunks)}\")\n",
    "print(f\"- Average chunk size: {sum(len(c.page_content) for c in chunks) / len(chunks):.1f} characters\")\n",
    "\n",
    "print(\"\\n--- Sample Chunk 1 Content Preview ---\")\n",
    "print(f\"Source Page: {chunks[0].metadata.get('page') + 1}\")\n",
    "print(chunks[0].page_content[:300])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 4: Local Embeddings Initialization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load sentence-transformers/all-MiniLM-L6-v2 model locally\n",
    "print(\"🔄 Loading local embedding model (sentence-transformers)...\\n\")\n",
    "embeddings = HuggingFaceEmbeddings(\n",
    "    model_name=\"sentence-transformers/all-MiniLM-L6-v2\",\n",
    "    encode_kwargs={'normalize_embeddings': True}\n",
    ")\n",
    "\n",
    "# Test encoding a single sentence\n",
    "test_text = \"Appendicitis causes acute right lower abdominal pain.\"\n",
    "vector = embeddings.embed_query(test_text)\n",
    "\n",
    "print(\"✅ Embedding Model Loaded.\")\n",
    "print(f\"- Output Vector Dimensions: {len(vector)} (Expected: 384)\")\n",
    "print(f\"- Vector preview (first 5 elements): {vector[:5]}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 5: Vector Store & Retrieval Metrics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# We will create an in-memory or local database and retrieve matching documents.\n",
    "# To measure metrics, we calculate similarity distance scores for the retrieved documents.\n",
    "print(\"🔄 Indexing chunks into local ChromaDB...\")\n",
    "db = Chroma.from_documents(\n",
    "    documents=chunks,\n",
    "    embedding=embeddings\n",
    ")\n",
    "\n",
    "test_query = \"Identify details about abdominal pain or appendix issues.\"\n",
    "\n",
    "# Query database directly using similarity_search_with_score to retrieve distance metrics\n",
    "# In ChromaDB with normalized embeddings, the score represents the L2 (Euclidean) distance.\n",
    "# Closer to 0 means higher semantic similarity.\n",
    "print(f\"\\n🔍 Query: '{test_query}'\")\n",
    "results_with_scores = db.similarity_search_with_score(test_query, k=3)\n",
    "\n",
    "print(\"\\n--- 📊 Retrieval Results & Similarity Metrics ---\")\n",
    "for idx, (doc, score) in enumerate(results_with_scores):\n",
    "    # Calculate cosine similarity estimate from normalized L2 distance\n",
    "    # Cosine Similarity = 1 - (L2_Distance^2 / 2)\n",
    "    cosine_sim = 1.0 - (score ** 2) / 2.0\n",
    "    print(f\"\\n[Chunk #{idx+1}]\")\n",
    "    print(f\"- Source: {doc.metadata.get('source')} (Page {doc.metadata.get('page') + 1})\")\n",
    "    print(f\"- L2 Distance (Chroma Score): {score:.4f} (Lower = closer)\")\n",
    "    print(f\"- Estimated Cosine Similarity: {cosine_sim:.4f} (Higher = closer)\")\n",
    "    print(f\"- Content Snippet: '{doc.page_content[:150]}...'\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 6: Grounded QA & Latency Metrics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Setup LLM and Prompt Template\n",
    "system_instruction = (\n",
    "    \"You are an expert Medical AI Assistant designed to answer questions accurately \"\n",
    "    \"using only the provided context. Follow these rules strictly:\\n\"\n",
    "    \"1. Answer the question using ONLY the provided clinical context. Do not use outside medical knowledge.\\n\"\n",
    "    \"2. Be concise, professional, and clear.\\n\"\n",
    "    \"3. If the retrieved context does not contain enough information to answer the question, \"\n",
    "    \"clearly state: 'I cannot answer this based on the provided document.'\\n\"\n",
    "    \"4. Never hallucinate, speculate, or make up facts. Your response must be grounded strictly in the source text.\\n\\n\"\n",
    "    \"--- Context ---\\n\"\n",
    "    \"{context}\\n\"\n",
    "    \"----------------\"\n",
    ")\n",
    "\n",
    "prompt_template = ChatPromptTemplate.from_messages([\n",
    "    (\"system\", system_instruction),\n",
    "    (\"human\", \"{question}\")\n",
    "])\n",
    "\n",
    "try:\n",
    "    # Initialize the LLM (Gemini 2.5 Flash)\n",
    "    llm = ChatGoogleGenerativeAI(\n",
    "        model=\"gemini-2.5-flash\",\n",
    "        google_api_key=api_key,\n",
    "        temperature=0.1\n",
    "    )\n",
    "    \n",
    "    # Combine context chunks for prompt injection\n",
    "    context_content = \"\\n\\n\".join([d.page_content for d in chunks])\n",
    "    \n",
    "    user_query = \"Explain the symptoms or core terms mentioned in the document.\"\n",
    "    \n",
    "    prompt_messages = prompt_template.format_messages(\n",
    "        context=context_content,\n",
    "        question=user_query\n",
    "    )\n",
    "    \n",
    "    print(f\"🔄 Sending prompt to Gemini LLM for query: '{user_query}'...\")\n",
    "    \n",
    "    # Start timer to measure response latency\n",
    "    start_time = time.time()\n",
    "    response = llm.invoke(prompt_messages)\n",
    "    latency = time.time() - start_time\n",
    "    \n",
    "    print(\"\\n--- 📊 Answer Generation & Latency Metrics ---\")\n",
    "    print(f\"- Response Time (Inference Latency): {latency:.3f} seconds\")\n",
    "    print(f\"- Answer: {response.content}\")\n",
    "    \n",
    "except Exception as e:\n",
    "    print(f\"❌ Failed to execute Gemini LLM query: {e}\")\n",
    "    print(\"Make sure you have set a valid GEMINI_API_KEY in your .env file.\")"
   ]
  }
 ],
