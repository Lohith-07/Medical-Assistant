# Medical RAG Assistant — .gitignore

# Virtual environments (if anyone clones and sets up locally)
venv/
.venv/
env/

# API keys — NEVER commit these
.env
*.key
secrets.json

# Python cache
__pycache__/
*.pyc
*.pyo

# Jupyter checkpoints
.ipynb_checkpoints/

# ChromaDB vector store (auto-generated, large)
chroma_db/

# HuggingFace model cache (auto-downloaded, ~90MB)
.cache/

# OS files
.DS_Store
Thumbs.db